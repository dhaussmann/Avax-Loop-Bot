# === RPC ===
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# === Wallet ===
# PRIVATE_KEY wird NICHT mehr in .env gespeichert!
# Der Private Key wird AES-256-GCM-verschlüsselt in wallet.enc gespeichert.
# Beim ersten Start ohne wallet.enc startet der Setup-Wizard automatisch.

